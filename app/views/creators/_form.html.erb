
<%= form_with(model: creator, local: false, class: 'space-y-6') do |form| %>
  <% if creator.errors.any? %>
    <div id="error_explanation" class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4">
      <h2 class="font-semibold text-lg"><%= pluralize(creator.errors.count, "error") %> prohibited this creator from being saved:</h2>
      <ul class="list-disc pl-5 mt-2">
        <% creator.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="flex flex-col space-y-2">
    <%= form.label :name, class: 'font-medium text-gray-700' %>
    <%= form.text_field :name, class: 'border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-blue-500' %>
  </div>

  <div class="flex flex-col space-y-2">
    <%= form.label :email, class: 'font-medium text-gray-700' %>
    <%= form.email_field :email, class: 'border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-blue-500' %>
  </div>

  <div class="flex flex-col space-y-2">
    <%= form.label :status, class: 'font-medium text-gray-700' %>
    <%= form.select :status, ['active', 'inactive'], {}, class: 'border border-gray-300 rounded-md p-2 focus:outline-none focus:ring-2 focus:ring-blue-500' %>
  </div>

  <div class="flex justify-between">
    <%= link_to 'Back', creators_path, class: 'bg-gray-500 text-white py-2 px-4 rounded-md hover:bg-gray-600 focus:outline-none focus:ring-2 focus:ring-gray-500', data: { turbo: false } %>

    <%= form.submit class: 'bg-blue-500 text-white py-2 px-4 rounded-md hover:bg-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-500' %>
  </div>
<% end %>
