<h1 class="text-3xl font-semibold text-gray-800 mb-6">Payouts Dashboard</h1>

<table class="min-w-full table-auto">
  <thead>
    <tr class="bg-gray-100 text-left">
      <th class="px-6 py-3 font-semibold text-sm text-gray-700 uppercase tracking-wider">ID</th>
      <th class="px-6 py-3 font-semibold text-sm text-gray-700 uppercase tracking-wider">Creator Name</th>
      <th class="px-6 py-3 font-semibold text-sm text-gray-700 uppercase tracking-wider">Total Paid</th>
      <th class="px-6 py-3 font-semibold text-sm text-gray-700 uppercase tracking-wider">Pending Payouts</th>
    </tr>
  </thead>

  <tbody>
    <% @creators.each_with_index do |creator, index| %>
      <tr class="<%= 'bg-gray-50' if index.even? %> <%= 'bg-gray-100' if index.odd? %> border-t border-b border-gray-200">
        <td class="px-6 py-4 text-gray-800"><%= creator.id %></td>
        <td class="px-6 py-4 text-gray-800"><%= creator.name %></td>
        <td class="px-6 py-4 text-gray-800"><%= number_to_currency(creator.total_paid_amount) %></td>
        <td class="px-6 py-4 text-gray-800"><%= creator.pending_payouts_count %></td>
      </tr>
    <% end %>
  </tbody>
</table>